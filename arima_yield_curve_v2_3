        "# ── Pull from FRED ────────────────────────────────────────────────────────────\n",
        "raw = web.DataReader([SERIES_MAIN, SERIES_SHORT], 'fred', START, END)\n",
        "raw.columns = ['Y_main', 'Y_short']\n",
        "raw.dropna(inplace=True)\n",
        "\n",
        "# ── Derived columns ───────────────────────────────────────────────────────────\n",
        "raw['spread'] = raw['Y_main'] - raw['Y_short']   # spread in pp\n",
        "raw['diff1']  = raw['Y_main'].diff()              # first difference (daily change)\n",
        "raw['diff2']  = raw['diff1'].diff()               # second difference (if needed)\n",
        "raw.dropna(inplace=True)\n",
        "\n",
        "# ── Summary ───────────────────────────────────────────────────────────────────\n",
        "n_obs       = len(raw)\n",
        "date_start  = raw.index[0].date()\n",
        "date_end    = raw.index[-1].date()\n",
        "n_years     = (raw.index[-1] - raw.index[0]).days / 365.25\n",
        "current_spread = raw['spread'].iloc[-1]\n",
        "\n",
        "print(f\"Series      : {SERIES_MAIN} ({SERIES_LABEL})\")\n",
        "print(f\"Period      : {date_start} → {date_end}  ({n_years:.1f} years)\")\n",
        "print(f\"Observations: {n_obs:,} trading days\")\n",
        "print(f\"\")\n",
        "print(f\"10Y range   : {raw['Y_main'].min():.2f}% – {raw['Y_main'].max():.2f}%\")\n",
        "print(f\"2Y  range   : {raw['Y_short'].min():.2f}% – {raw['Y_short'].max():.2f}%\")\n",
        "print(f\"Spread range: {raw['spread'].min():.2f}pp – {raw['spread'].max():.2f}pp\")\n",
        "print(f\"Current spread: {current_spread:.2f}pp  →  {'INVERTED ⚠' if current_spread < 0 else 'Normal ✓'}\")\n",
        "raw.tail()"
      ]
