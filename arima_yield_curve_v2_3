        "# ── Test functions ────────────────────────────────────────────────────────────\n",
        "def adf_test(series, regression='c'):\n",
        "    \"\"\"Returns (statistic, p-value, critical_values, is_stationary).\"\"\"\n",
        "    stat, pval, lags, _, crit, _ = adfuller(series.dropna(), regression=regression, autolag='AIC')\n",
        "    is_stat = pval < ALPHA_STAT\n",
        "    return stat, pval, crit, is_stat\n",
        "\n",
        "def kpss_test(series, regression='c'):\n",
        "    \"\"\"Returns (statistic, p-value, is_stationary).\"\"\"\n",
        "    stat, pval, _, _ = kpss(series.dropna(), regression=regression, nlags='auto')\n",
        "    is_stat = pval >= ALPHA_STAT   # fail to reject H0 → stationary\n",
        "    return stat, pval, is_stat\n",
        "\n",
        "def combo_verdict(adf_stat, kpss_stat):\n",
        "    if adf_stat and kpss_stat:       return 'Stationary ✓'\n",
        "    if not adf_stat and not kpss_stat: return 'Non-stationary ✗'\n",
        "    if adf_stat and not kpss_stat:   return 'Trend-stationary (detrend)'\n",
        "    return 'Inconclusive'\n",
        "\n",
        "def significance_stars(pval):\n",
        "    if pval < 0.01:  return '***'\n",
        "    if pval < 0.05:  return '**'\n",
        "    if pval < 0.10:  return '*'\n",
        "    return ''\n",
        "\n",
        "# ── Run on levels, diff1, diff2 ───────────────────────────────────────────────\n",
        "# Use 'ct' (constant + trend) for levels, 'c' for differences\n",
        "series_to_test = [\n",
        "    ('Levels',  raw['Y_main'],  'ct'),\n",
        "    ('Diff(1)', raw['diff1'],   'c'),\n",
        "    ('Diff(2)', raw['diff2'],   'c'),\n",
        "]\n",
        "\n",
        "results = []\n",
        "print(f\"Significance level: α = {ALPHA_STAT}\")\n",
        "print()\n",
        "\n",
        "for name, series, reg in series_to_test:\n",
        "    adf_s, adf_p, adf_crit, adf_ok = adf_test(series, regression=reg)\n",
        "    kpss_s, kpss_p, kpss_ok        = kpss_test(series, regression=reg)\n",
        "    verdict = combo_verdict(adf_ok, kpss_ok)\n",
        "\n",
        "    results.append({\n",
        "        'series': name, 'adf_ok': adf_ok, 'kpss_ok': kpss_ok,\n",
        "        'adf_stat': adf_s, 'adf_p': adf_p,\n",
        "        'kpss_stat': kpss_s, 'kpss_p': kpss_p,\n",
        "        'verdict': verdict\n",
        "    })\n",
        "\n",
        "    print(f\"── {name} (regression='{reg}') ──\")\n",
        "    print(f\"  ADF  stat={adf_s:7.4f}  p={adf_p:.4f}{significance_stars(adf_p):3s}  crit5%={adf_crit['5%']:.3f}  → {'stationary' if adf_ok else 'non-stationary'}\")\n",
        "    print(f\"  KPSS stat={kpss_s:7.4f}  p={kpss_p:.4f}{significance_stars(kpss_p):3s}                      → {'stationary' if kpss_ok else 'non-stationary'}\")\n",
        "    print(f\"  Combined: {verdict}\")\n",
        "    print()\n",
        "\n",
        "# ── Summary table ─────────────────────────────────────────────────────────────\n",
        "print(f\"{'Series':<10} {'ADF':<18} {'KPSS':<18} {'Verdict'}\")\n",
        "print('─' * 70)\n",
        "for r in results:\n",
        "    adf_str  = f\"p={r['adf_p']:.3f} {'stat' if r['adf_ok'] else 'non-stat'}\"\n",
        "    kpss_str = f\"p={r['kpss_p']:.3f} {'stat' if r['kpss_ok'] else 'non-stat'}\"\n",
        "    print(f\"{r['series']:<10} {adf_str:<18} {kpss_str:<18} {r['verdict']}\")\n",
        "\n",
        "# ── Automatically select d ────────────────────────────────────────────────────\n",
        "d_selected = None\n",
        "stationary_series = None\n",
        "for i, r in enumerate(results):\n",
        "    if r['adf_ok'] and r['kpss_ok']:\n",
        "        d_selected = i\n",
